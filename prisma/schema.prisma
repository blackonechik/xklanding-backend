generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum PromoCodeDiscountType {
  percent
  fixed
}

model Payment {
  id                String           @id @default(uuid()) @db.Uuid
  nickname          String
  productId         String           @map("product_id")
  productName       String           @map("product_name")
  amountRub         Int              @map("amount_rub")
  discountRub       Int              @default(0) @map("discount_rub")
  status            String
  provider          String           @default("yookassa")
  providerPaymentId String?          @map("provider_payment_id")
  confirmationUrl   String           @map("confirmation_url")
  promoCodeId       String?          @map("promo_code_id") @db.Uuid
  metadata          Json             @default("{}")
  createdAt         DateTime         @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt         DateTime         @updatedAt @map("updated_at") @db.Timestamptz(6)
  lifePurchaseLog   LifePurchaseLog?
  promoCode         PromoCode?       @relation(fields: [promoCodeId], references: [id], onDelete: SetNull)

  @@map("payments")
}

model PromoCode {
  id                 String                @id @default(uuid()) @db.Uuid
  code               String                @unique
  discountType       PromoCodeDiscountType @map("discount_type")
  discountValue      Int                   @map("discount_value")
  maxUses            Int?                  @map("max_uses")
  maxUsesPerNickname Int?                  @map("max_uses_per_nickname")
  usedCount          Int                   @default(0) @map("used_count")
  isActive           Boolean               @default(true) @map("is_active")
  startsAt           DateTime?             @map("starts_at") @db.Timestamptz(6)
  endsAt             DateTime?             @map("ends_at") @db.Timestamptz(6)
  createdAt          DateTime              @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt          DateTime              @updatedAt @map("updated_at") @db.Timestamptz(6)
  payments           Payment[]

  @@map("promo_codes")
}

model LifePurchaseLog {
  id                String   @id @default(uuid()) @db.Uuid
  orderId           String   @unique @map("order_id") @db.Uuid
  paymentId         String   @unique @map("payment_id") @db.Uuid
  providerPaymentId String   @map("provider_payment_id")
  playerUuid        String   @map("player_uuid")
  playerName        String   @map("player_name")
  productId         String   @map("product_id")
  livesDelta        Int      @map("lives_delta")
  previousLives     Int      @map("previous_lives")
  newLives          Int      @map("new_lives")
  createdAt         DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  payment Payment @relation(fields: [paymentId], references: [id], onDelete: Cascade)

  @@map("life_purchase_log")
}

model WhitelistEntry {
  nickname   String   @id @db.VarChar(16)
  active     Boolean  @default(true)
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt  DateTime @default(now()) @map("updated_at") @db.Timestamptz(6)
  purchaseId BigInt?  @map("purchase_id")
  source     String?  @db.VarChar(32)

  @@map("whitelist_entries")
}

model BankCard {
  id              String         @id @default(uuid()) @db.Uuid
  ownerNickname   String         @map("owner_nickname") @db.VarChar(16)
  ownerLowercase  String         @map("owner_lowercase") @db.VarChar(16)
  title           String         @db.VarChar(40)
  cardNumber      String         @unique @map("card_number") @db.VarChar(19)
  design          String         @default("creeper") @db.VarChar(32)
  balanceDiamonds Int            @default(0) @map("balance_diamonds")
  isActive        Boolean        @default(true) @map("is_active")
  createdAt       DateTime       @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt       DateTime       @updatedAt @map("updated_at") @db.Timestamptz(6)
  outgoing        BankTransfer[] @relation("OutgoingTransfers")
  incoming        BankTransfer[] @relation("IncomingTransfers")

  @@index([ownerLowercase])
  @@map("bank_cards")
}

model BankTransfer {
  id             String   @id @default(uuid()) @db.Uuid
  fromCardId     String   @map("from_card_id") @db.Uuid
  toCardId       String   @map("to_card_id") @db.Uuid
  fromOwner      String   @map("from_owner") @db.VarChar(16)
  toOwner        String   @map("to_owner") @db.VarChar(16)
  amountDiamonds Int      @map("amount_diamonds")
  comment        String?  @db.VarChar(120)
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  fromCard       BankCard @relation("OutgoingTransfers", fields: [fromCardId], references: [id], onDelete: Restrict)
  toCard         BankCard @relation("IncomingTransfers", fields: [toCardId], references: [id], onDelete: Restrict)

  @@index([fromCardId])
  @@index([toCardId])
  @@map("bank_transfers")
}

model PlayerProfile {
  nickname   String   @id @db.VarChar(16)
  animation  String   @default("inspect") @db.VarChar(16)
  background String   @default("default") @db.VarChar(16)
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt  DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@map("player_profiles")
}

model PlayTimePlayer {
  uuid               String                @id @db.VarChar(36)
  nickname           String                @unique @db.VarChar(36)
  playtime           BigInt
  artificialPlaytime BigInt                @map("artificial_playtime")
  afkPlaytime        BigInt                @map("afk_playtime")
  lastSeen           BigInt?               @map("last_seen")
  firstJoin          BigInt?               @map("first_join")
  relativeJoinStreak Int                   @default(0) @map("relative_join_streak")
  absoluteJoinStreak Int                   @default(0) @map("absolute_join_streak")
  dailyActivity      PlayerDailyActivity[]
  onlineStatus       PlayerOnlineStatus?

  @@map("play_time")
}

model PlayerDailyActivity {
  userUuid      String         @map("user_uuid") @db.VarChar(36)
  nickname      String         @db.VarChar(36)
  activityDate  DateTime       @map("activity_date") @db.Date
  playedSeconds BigInt         @default(0) @map("played_seconds")
  updatedAt     DateTime       @default(now()) @map("updated_at") @db.Timestamptz(6)
  player        PlayTimePlayer @relation(fields: [userUuid], references: [uuid], onDelete: Cascade)

  @@id([userUuid, activityDate])
  @@index([nickname, activityDate], map: "idx_player_daily_activity_nickname_date")
  @@map("player_daily_activity")
}

model PlayerOnlineStatus {
  userUuid  String         @id @map("user_uuid") @db.VarChar(36)
  nickname  String         @db.VarChar(36)
  online    Boolean        @default(false)
  updatedAt DateTime       @default(now()) @map("updated_at") @db.Timestamptz(6)
  player    PlayTimePlayer @relation(fields: [userUuid], references: [uuid], onDelete: Cascade)

  @@index([nickname], map: "idx_player_online_status_nickname")
  @@map("player_online_status")
}

model PlayerRating {
  targetNickname String   @map("target_nickname") @db.VarChar(16)
  voterNickname  String   @map("voter_nickname") @db.VarChar(16)
  value          Int
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt      DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@id([targetNickname, voterNickname])
  @@index([voterNickname])
  @@map("player_ratings")
}
